    for char in payload:
        result += chr(ord(char) ^ key)
    return result
🟢 4. rot13_encoder.py
def encode(payload):
    result = ""
    for char in payload:
        if char.isalpha():
            shift = 13
            base = ord('a') if char.islower() else ord('A')
            result += chr((ord(char) - base + shift) % 26 + base)
        else:
            result += char
    return result
