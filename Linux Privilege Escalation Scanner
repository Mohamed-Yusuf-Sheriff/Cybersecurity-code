import os
import platform

def get_system_info():
    info = {}

    info["User"] = os.getenv("USER")
    info["Home Directory"] = os.path.expanduser("~")
    info["OS"] = platform.system()
    info["Kernel"] = platform.release()

    return info
🟢 2. suid_scan.py
import subprocess

def scan_suid():
    try:
        result = subprocess.check_output(
            "find / -perm -4000 -type f 2>/dev/null",
            shell=True,
            text=True
        )
        return result.split("\n")[:10]  # limit output
    except:
        return []
