🟢 7. main.py (IMPORTANT)
from modules.system_info import get_system_info
from modules.suid_scan import scan_suid
from modules.permission_scan import scan_world_writable
from modules.sudo_check import check_sudo
from modules.cron_scan import scan_cron
from modules.kernel_check import get_kernel

def main():
    print("\n=== Linux Privilege Escalation Audit Tool ===\n")

    report = []

    # -------------------------
    # System Info
    # -------------------------
    info = get_system_info()
    print("System Info:")
    for k, v in info.items():
        print(f"{k}: {v}")
        report.append(f"{k}: {v}\n")

    report.append("\n")

    # -------------------------
    # SUID Scan
    # -------------------------
    print("\nScanning SUID Binaries...")
    suid_files = scan_suid()

    report.append("SUID Binaries:\n")
    for f in suid_files:
        if f:
            print(f)
            report.append(f + "\n")

    report.append("\n")

    # -------------------------
    # World Writable Scan
    # -------------------------
    print("\nScanning World-Writable Files...")
    writable = scan_world_writable()

    report.append("World Writable Files:\n")
    for f in writable:
        if f:
            print(f)
            report.append(f + "\n")

    report.append("\n")

    # -------------------------
    # Sudo Check
    # -------------------------
    print("\nChecking Sudo Permissions...")
    sudo = check_sudo()
    print(sudo)
    report.append("Sudo Configuration:\n" + sudo + "\n")

    # -------------------------
    # Cron Scan
    # -------------------------
    print("\nChecking Cron Jobs...")
    cron = scan_cron()
    print(cron)
    report.append("Cron Jobs:\n" + cron + "\n")

    # -------------------------
    # Kernel Info
    # -------------------------
    kernel = get_kernel()
    print("\nKernel Version:", kernel)
    report.append(f"\nKernel Version: {kernel}\n")

    # -------------------------
    # Save Report
    # -------------------------
    with open("reports/scan_report.txt", "w") as f:
        f.writelines(report)

    print("\nReport saved: reports/scan_report.txt")

if __name__ == "__main__":
    main()
